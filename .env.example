# Copy this file to ".env" (no extension prefix) and fill in real values.
# Never commit your real .env to git.

# Your DSB Plus account email
DSB_EMAIL=your.email@example.com

# Your DSB Plus account password
DSB_PASSWORD=replace-me

# Car license plate to register. Defaults to CJ73789 if omitted.
LICENSE_PLATE=CJ73789

# "1" = run the browser invisibly. "0" = show the Chromium window.
# Recommended: 0 the first time so you can watch what happens.
HEADLESS=0
