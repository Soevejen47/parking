# Copy this file to ".env" and fill in real values.
# Never commit your real .env (it is gitignored).

# --- required ----------------------------------------------------------------

# Account login used for the operator's site.
LOGIN_EMAIL=your.login@example.com
LOGIN_PASSWORD=replace-me

# One or more "PLATE:receipt-email" entries. Separator can be commas OR
# newlines. The receipt email is where the operator's confirmation is sent;
# it does NOT have to match LOGIN_EMAIL. Lines starting with '#' are ignored.
#
# Single car:
#   REGISTRATIONS=AB12345:owner@example.com
#
# Multiple cars (one receipt address):
#   REGISTRATIONS=AB12345:owner@example.com,CD67890:owner@example.com
#
# Multiple cars (different receipt addresses):
#   REGISTRATIONS=AB12345:alice@example.com,CD67890:bob@example.com
REGISTRATIONS=AB12345:owner@example.com

# --- optional ----------------------------------------------------------------

# "1" = headless (no browser window). "0" = visible (good for first-time use).
HEADLESS=0

# Tuning. Defaults are fine for most cases.
# TIMEOUT_MS=20000
# MAX_ATTEMPTS=2
