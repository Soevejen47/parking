# Copy this file to ".env" and fill in real values.
# Never commit your real .env.

# Account email
LOGIN_EMAIL=your.email@example.com

# Account password
LOGIN_PASSWORD=replace-me

# License plate to register (required).
LICENSE_PLATE=AB12345

# "1" = run the browser invisibly. "0" = show the Chromium window.
# Recommended: 0 the first time so you can watch what happens.
HEADLESS=0
