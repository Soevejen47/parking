# Copy this file to ".env" and fill in real values.
# Never commit your real .env.

# Account login used for the operator's site.
LOGIN_EMAIL=your.login@example.com
LOGIN_PASSWORD=replace-me

# One or more "PLATE:receipt-email" entries, separated by commas or newlines.
# The receipt email is where the operator sends the parking confirmation;
# it does not have to match LOGIN_EMAIL.
REGISTRATIONS=AB12345:owner@example.com,CD67890:friend@example.com

# "1" = run the browser invisibly. "0" = show the Chromium window.
HEADLESS=0

# Optional tuning. Defaults are fine for most cases.
# TIMEOUT_MS=20000
# MAX_ATTEMPTS=2
